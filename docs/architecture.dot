digraph DocFinder {
    graph [
        fontname = "Helvetica Neue,Helvetica,Arial,sans-serif"
        fontsize = 18
        bgcolor = "#FFFFFF"
        pad = 0.5
        nodesep = 0.5
        ranksep = 0.8
        splines = true
        rankdir = TB
        label = "Doc Finder — System Architecture"
        labelloc = t
        labeljust = c
        fontcolor = "#1a1a2e"
    ]
    node [
        fontname = "Helvetica Neue,Helvetica,Arial,sans-serif"
        fontsize = 11
        shape = box
        style = "filled,rounded"
        margin = "0.2,0.12"
    ]
    edge [
        fontname = "Helvetica Neue,Helvetica,Arial,sans-serif"
        fontsize = 9
        color = "#666688"
        fontcolor = "#333355"
        penwidth = 1.4
        arrowsize = 0.75
    ]

    /* ─── User (outside the app) ─────────────────────────────── */
    USER [
        label = "User\n(Browser)"
        fillcolor = "#3A7DC9"
        fontcolor = "#FFFFFF"
        color = "#1E5B9A"
        shape = ellipse
    ]

    /* ─── Databricks App ─────────────────────────────────────── */
    subgraph cluster_app {
        label = "Databricks App"
        style = "filled,rounded"
        color = "#7B5EA7"
        fillcolor = "#F3EEF9"
        fontname = "Helvetica Neue,Helvetica,Arial,sans-serif"
        fontsize = 12
        fontcolor = "#3D1F6E"
        penwidth = 2

        FRONTEND [
            label = "React Frontend\n(CDN-loaded)"
            fillcolor = "#FFFFFF"
            color = "#3A7DC9"
            fontcolor = "#1A3A5C"
        ]
        FASTAPI [
            label = "FastAPI\nBackend"
            fillcolor = "#FFFFFF"
            color = "#7B5EA7"
            fontcolor = "#3D1F6E"
        ]
        HAIKU [
            label = "Claude Haiku 4.5\n(Query Classifier)"
            fillcolor = "#EDE0F8"
            color = "#7B5EA7"
            fontcolor = "#3D1F6E"
        ]
        SONNET [
            label = "Claude Sonnet 4.6\n(Response Generator)"
            fillcolor = "#EDE0F8"
            color = "#7B5EA7"
            fontcolor = "#3D1F6E"
        ]

        /* Layout: Frontend on top, FastAPI below, Haiku+Sonnet at bottom */
        FRONTEND -> FASTAPI [style = invis]
        FASTAPI -> HAIKU [style = invis]
        FASTAPI -> SONNET [style = invis]
        { rank = same; HAIKU; SONNET }
    }

    /* ─── Data Sources ───────────────────────────────────────── */
    subgraph cluster_data {
        label = "Data Sources  (Unity Catalog)"
        style = "filled,rounded"
        color = "#D96A20"
        fillcolor = "#FDF3EB"
        fontname = "Helvetica Neue,Helvetica,Arial,sans-serif"
        fontsize = 12
        fontcolor = "#7A3A10"
        penwidth = 2

        VS [
            label = "Vector Search\nHybrid mode"
            fillcolor = "#FFFFFF"
            color = "#D96A20"
            fontcolor = "#7A3A10"
        ]
        SQLWH [
            label = "SQL Warehouse\nILIKE keyword search"
            fillcolor = "#FFFFFF"
            color = "#D96A20"
            fontcolor = "#7A3A10"
        ]
        UCVOL [
            label = "UC Volume\n(PDF files)"
            fillcolor = "#FFFFFF"
            color = "#D96A20"
            fontcolor = "#7A3A10"
            shape = cylinder
        ]
    }

    /* ─── Observability ──────────────────────────────────────── */
    subgraph cluster_obs {
        label = "Observability"
        style = "filled,rounded"
        color = "#2A8050"
        fillcolor = "#E8F5EE"
        fontname = "Helvetica Neue,Helvetica,Arial,sans-serif"
        fontsize = 12
        fontcolor = "#1A5C35"
        penwidth = 2

        MLFLOW [
            label = "MLflow Tracing\n/Shared/doc-finder"
            fillcolor = "#FFFFFF"
            color = "#2A8050"
            fontcolor = "#1A5C35"
        ]
    }

    /* ─── Data Pipeline ──────────────────────────────────────── */
    subgraph cluster_pipeline {
        label = "Data Pipeline  (DABs Job)"
        style = "filled,rounded"
        color = "#9A7030"
        fillcolor = "#FDF7ED"
        fontname = "Helvetica Neue,Helvetica,Arial,sans-serif"
        fontsize = 12
        fontcolor = "#6B4A10"
        penwidth = 2

        RAWDOCS [
            label = "raw_docs/"
            fillcolor = "#FFFFFF"
            color = "#9A7030"
            fontcolor = "#6B4A10"
            shape = folder
        ]
        AIPARSE [
            label = "ai_parse_document()"
            fillcolor = "#FFFFFF"
            color = "#9A7030"
            fontcolor = "#6B4A10"
        ]
        GEMINI [
            label = "Gemini 2.5 Pro\n(Summarization)"
            fillcolor = "#FFF3D6"
            color = "#9A7030"
            fontcolor = "#6B4A10"
        ]
        DELTATABLE [
            label = "doc_summaries\n(Delta Table)"
            fillcolor = "#FFFFFF"
            color = "#9A7030"
            fontcolor = "#6B4A10"
            shape = cylinder
        ]
        VSINDEX [
            label = "VS Index\nDelta Sync"
            fillcolor = "#FFF3D6"
            color = "#9A7030"
            fontcolor = "#6B4A10"
        ]
    }

    /* ─── Legend ─────────────────────────────────────────────── */
    subgraph cluster_legend {
        label = "Legend"
        style = "filled,rounded"
        color = "#AAAAAA"
        fillcolor = "#F8F8F8"
        fontname = "Helvetica Neue,Helvetica,Arial,sans-serif"
        fontsize = 9
        fontcolor = "#555555"
        penwidth = 1
        margin = 6
        rankdir = TB

        node [shape = point width = 0 height = 0 fillcolor = "#F8F8F8" color = "#F8F8F8"]

        L1a [label = ""]
        L1b [label = "Data flow" shape = plaintext fontsize = 8 fontcolor = "#555555" margin = "0.02,0.02"]
        L1a -> L1b [color = "#666688" penwidth = 1.2 arrowsize = 0.5]

        L2a [label = ""]
        L2b [label = "Parallel search" shape = plaintext fontsize = 8 fontcolor = "#555555" margin = "0.02,0.02"]
        L2a -> L2b [style = dashed color = "#666688" penwidth = 1.2 arrowsize = 0.5]

        L3a [label = ""]
        L3b [label = "MLflow trace" shape = plaintext fontsize = 8 fontcolor = "#555555" margin = "0.02,0.02"]
        L3a -> L3b [style = dotted color = "#2A8050" penwidth = 1.2 arrowsize = 0.5]

        /* Stack vertically */
        L1b -> L2a [style = invis]
        L2b -> L3a [style = invis]
    }

    /* ─── User Flow ─────────────────────────────────────────── */
    USER -> FRONTEND [label = "chat / view PDF" dir = both]
    FRONTEND -> FASTAPI [label = "API calls" dir = both]

    /* ─── Search Agent Flow ─────────────────────────────────── */
    /* FastAPI sends query to Haiku for classification */
    FASTAPI -> HAIKU [label = "user query"]

    /* Haiku fans out to both search backends in parallel */
    HAIKU -> VS [label = "semantic query" style = dashed]
    HAIKU -> SQLWH [label = "keyword terms" style = dashed]

    /* Search results flow to Sonnet for response generation */
    VS -> SONNET [label = "results"]
    SQLWH -> SONNET [label = "results"]

    /* Sonnet returns answer to FastAPI */
    SONNET -> FASTAPI [label = "answer + filename"]

    /* FastAPI serves PDFs from volume */
    FASTAPI -> UCVOL [label = "fetch / serve PDF" dir = both]

    /* ─── Observability ─────────────────────────────────────── */
    HAIKU -> MLFLOW [
        label = "trace"
        color = "#2A8050"
        fontcolor = "#2A8050"
        style = dotted
        penwidth = 1.2
    ]
    SONNET -> MLFLOW [
        label = "trace"
        color = "#2A8050"
        fontcolor = "#2A8050"
        style = dotted
        penwidth = 1.2
    ]

    /* ─── Pipeline Flow ─────────────────────────────────────── */
    RAWDOCS -> UCVOL [label = "upload"]
    UCVOL -> AIPARSE [label = "read PDFs"]
    AIPARSE -> GEMINI [label = "parsed text"]
    GEMINI -> DELTATABLE [label = "summaries"]
    DELTATABLE -> VSINDEX [label = "Delta Sync"]
    VSINDEX -> VS [label = "serves index"]
}
